{"number": 4383, "title": "fix: add canary deployment step for cache config changes", "state": "open", "merged": false, "draft": false, "body": "Prevents future incidents by requiring a 5-minute canary window for all CDN config changes. Postmortem action item from INC-804.", "user__login": "Alice", "user": "Alice", "base__ref": "main", "head__label": "fix/canary-deploy", "created_at": "2026-05-28T11:01:51.055378Z", "merged_at": null, "closed_at": null, "updated_at": "2026-05-28T10:01:51.055378Z", "html_url": "https://github.com/acme-corp/cdn-infra/pull/4383", "additions": 55, "deletions": 10, "changed_files": 3, "comments": 8, "commits": 3, "mergeable_state": "clean", "owner": "acme-corp", "repo": "cdn-infra"}
{"number": 4384, "title": "feat: add automated cache-hit-ratio canary check to deploy pipeline", "state": "open", "merged": false, "draft": false, "body": "Checks that cache hit ratio doesn't drop below 50% within 2 minutes of deploy. If it does, auto-rollback. Postmortem action item from INC-804.", "user__login": "Charlie", "user": "Charlie", "base__ref": "main", "head__label": "feat/cache-ratio-canary", "created_at": "2026-05-28T11:11:51.055378Z", "merged_at": null, "closed_at": null, "updated_at": "2026-05-28T10:06:51.055378Z", "html_url": "https://github.com/acme-corp/cdn-infra/pull/4384", "additions": 120, "deletions": 5, "changed_files": 6, "comments": 3, "commits": 4, "mergeable_state": "clean", "owner": "acme-corp", "repo": "cdn-infra"}
